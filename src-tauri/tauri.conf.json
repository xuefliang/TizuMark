{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "TizuMark",
  "version": "1.0.6",
  "identifier": "com.tizu.markdown",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TizuMark",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": false,
        "devtools": true,
        "maximized": true,
        "backgroundColor": "#f5f5f5"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' data: blob: https:; media-src 'self' blob:; frame-src 'self'; connect-src 'self' ipc: tauri: https:; worker-src 'self' blob:; child-src 'self' blob:"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tizuio/TizuMark/releases/latest/download/update-windows-x86_64.json",
        "https://gitee.com/tizu/tizu-mark/raw/master/update-windows-x86_64.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5OUJDOEQwRTc3MzVCNjUKUldSbFczUG4wTWlicVppTUk2QW5oY1RxR0hrUzJKMGZyeE1Ta20rOWVCbWVEejdEOWx1K3ppcWgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installMode": "currentUser"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown",
        "description": "Markdown Document",
        "mimeType": "text/markdown"
      }
    ]
  }
}
